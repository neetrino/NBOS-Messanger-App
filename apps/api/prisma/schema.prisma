generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  messagesSent Message[]               @relation("MessageSender")
  memberships  ConversationMember[]
}

model Conversation {
  id        String   @id @default(cuid())
  title     String?
  createdAt DateTime @default(now())

  members   ConversationMember[]
  messages  Message[]
  chatFiles ChatFile[]
}

model ConversationMember {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id                     String    @id @default(cuid())
  conversationId         String
  senderId               String
  body                   String
  /// Denormalized attachment metadata (see ChatFile for authoritative file record)
  attachment             Json?
  createdAt              DateTime  @default(now())
  /// User ids for whom this message is hidden (delete for me)
  hiddenForUserIds       String[]  @default([])
  /// When set, message is deleted for all participants (tombstone in API)
  deletedForEveryoneAt   DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  linkedFile   ChatFile?

  @@index([conversationId, createdAt])
}

model ChatFile {
  id                 String    @id @default(cuid())
  conversationId   String
  uploadedByUserId String
  /// Filename within uploads/chat/
  storageFileName  String
  originalName     String
  mimeType         String
  sizeBytes        Int
  kind             String
  createdAt        DateTime  @default(now())
  messageId        String?   @unique

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([conversationId, uploadedByUserId])
}
