# Monorepo root — copy once to `.env` in this same folder (repository root).
# All apps read from here: API (Nest + Prisma), Web (Next), Mobile (Expo).
# Optional overrides: `apps/api/.env`, `apps/web/.env.local`, `apps/mobile/.env` (later keys win where supported).

# --- API (Nest + Prisma) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dbname?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
PORT=4000
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# --- Web (Next.js) — only NEXT_PUBLIC_* is exposed to the browser ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Mobile (Expo) — optional in dev; set for production / EAS ---
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
