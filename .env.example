# Single source of truth: copy this file to `.env` in this same folder (repository root).
# API, Next.js, Prisma CLI, and Expo all read from `/.env` only.

# --- API (Nest + Prisma) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dbname?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
PORT=4000
# Next (3000) + Expo web dev (8081). Non-production API also allows 8081 automatically.
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081

# --- Web (Next.js) + Mobile (Expo Metro) — public, embedded in bundles ---
# Local dev on PC/emulator:
NEXT_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
# Physical phone (Expo Go / dev client on LAN): you can keep localhost above — the app maps it
# to the same host as Metro (your PC Wi‑Fi IPv4) when that host is not loopback.
# If Metro uses --tunnel, set an explicit LAN or tunneled API URL instead.
# Optional explicit override (same value for both), e.g.
# NEXT_PUBLIC_API_URL=http://192.168.1.10:4000
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4000

# Production example:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
